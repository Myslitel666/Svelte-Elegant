{
	"name": "svelte-elegant",
	"version": "0.1.35",
	"scripts": {
		"clean": "rimraf dist",
		"dev": "vite dev --open",
		"build": "npm run clean && vite build && npm run package",
		"preview": "vite preview",
		"package": "npm run clean && svelte-kit sync && svelte-package",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Myslitel666/Svelte-Elegant.git"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^4.0.0",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/package": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"publint": "^0.3.2",
		"rimraf": "^6.0.1",
		"svelte": "^5.0.0",
		"typescript": "^5.3.2",
		"vite": "^6.0.0"
	},
	"dependencies": {
		"svelte2tsx": "^0.7.34"
	}
}
